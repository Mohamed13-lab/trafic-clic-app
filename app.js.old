app.get('/api/attente', (req, res) => {
  db.all(`SELECT a.*, c.nom, c.telephone FROM attente a JOIN clients c ON a.client_id = c.id WHERE a.actif = 1`, (err, rows) => {
    if (err) return res.status(500).json({ error: err.message });
    res.json(rows);
  });
});

app.post('/api/attente', (req, res) => {
  const { client_id, depart, arrivee, type_vehicule, heure_debut, date_souhaitee, heure_souhaitee, nb_places } = req.body;
  if (!client_id || !depart || !arrivee || !date_souhaitee) {
    return res.status(400).json({ error: 'Champs requis' });
  }
  db.run(
    `INSERT INTO attente (client_id, depart, arrivee, type_vehicule, heure_debut, date_souhaitee, heure_souhaitee, nb_places, actif)
     VALUES (?, ?, ?, ?, ?, ?, ?, ?, 1)`,
    [client_id, depart, arrivee, type_vehicule || (nb_places ? nb_places + ' places' : ''), heure_debut, date_souhaitee, heure_souhaitee || null, nb_places || 0],
    function(err) {
      if (err) return res.status(500).json({ error: err.message });
      res.json({ id: this.lastID, message: 'Demande ajoutée' });
    }
  );
});

app.get('/api/attente', (req, res) => {
  db.all(`SELECT a.*, c.nom, c.telephone FROM attente a JOIN clients c ON a.client_id = c.id WHERE a.actif = 1`, (err, rows) => {
    if (err) return res.status(500).json({ error: err.message });
    res.json(rows);
  });
});
