<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Trafic Clic – Covoiturage</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', Roboto, sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 20px;
      /* --- NOUVEAU FOND --- */
      background: linear-gradient(145deg, #f8f0e6 0%, #fde68a 40%, #f59e0b 100%);
      position: relative;
      overflow-x: hidden;
    }
    /* --- BLOCS FLUOS (décoratifs) --- */
    .blob {
      position: fixed;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.4;
      z-index: 0;
      pointer-events: none;
    }
    .blob1 {
      width: 500px;
      height: 500px;
      background: #fbbf24;
      top: -150px;
      left: -100px;
    }
    .blob2 {
      width: 400px;
      height: 400px;
      background: #f472b6;
      bottom: -100px;
      right: -50px;
    }
    .blob3 {
      width: 300px;
      height: 300px;
      background: #60a5fa;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
    }
    /* --- CONTENEUR PRINCIPAL --- */
    .container {
      max-width: 1200px;
      width: 100%;
      background: rgba(255, 255, 255, 0.75);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-radius: 40px;
      padding: 40px 30px;
      box-shadow: 0 30px 60px rgba(0,0,0,0.15);
      text-align: center;
      position: relative;
      z-index: 1;
      border: 1px solid rgba(255,255,255,0.3);
    }
    /* --- LOGO --- */
    .logo-area {
      display: flex;
      flex-direction: column;
      align-items: center;
      margin-bottom: 20px;
    }
    .logo-main {
      font-size: 5rem;
      font-weight: 900;
      color: #1a365d;
      letter-spacing: 6px;
      line-height: 1.2;
      text-shadow: 0 4px 30px rgba(26, 54, 93, 0.2);
    }
    .logo-main .highlight {
      color: #f6ad55;
      display: inline-block;
      margin: 0 4px;
    }
    .logo-main .arrow {
      color: #f6ad55;
      font-size: 4.5rem;
      margin: 0 4px;
    }
    .logo-main .cursor {
      color: #f6ad55;
      font-size: 4.5rem;
      margin: 0 4px;
    }
    .logo-sub {
      font-size: 1.4rem;
      color: #4a5568;
      margin-top: 6px;
      font-weight: 300;
      letter-spacing: 2px;
    }
    /* --- BANNIÈRE PUB --- */
    .pub-banner {
      background: linear-gradient(90deg, #2b6cb0, #63b3ed);
      color: white;
      padding: 15px 20px;
      border-radius: 50px;
      font-weight: 600;
      margin-bottom: 40px;
      font-size: 1.1rem;
      box-shadow: 0 4px 15px rgba(43,108,176,0.3);
    }
    /* --- CHOIX --- */
    .choice-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 30px;
      margin: 30px 0;
    }
    @media (max-width: 700px) { .choice-grid { grid-template-columns: 1fr; } }
    .choice-card {
      background: rgba(255,255,255,0.85);
      backdrop-filter: blur(4px);
      border-radius: 24px;
      padding: 35px 25px;
      box-shadow: 0 8px 25px rgba(0,0,0,0.08);
      transition: transform 0.2s, box-shadow 0.2s;
      cursor: pointer;
      border: 2px solid transparent;
      text-decoration: none;
      color: inherit;
      display: block;
    }
    .choice-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 15px 40px rgba(0,0,0,0.15);
      border-color: #2b6cb0;
    }
    .choice-card .icon { font-size: 4rem; margin-bottom: 15px; }
    .choice-card h2 { font-size: 1.8rem; color: #1a365d; margin-bottom: 8px; }
    .choice-card p { color: #4a5568; font-size: 1rem; line-height: 1.5; }
    .choice-card.chauffeur { border-left: 6px solid #ed8936; }
    .choice-card.client { border-left: 6px solid #48bb78; }
    /* --- FOOTER --- */
    .footer-links {
      margin-top: 40px;
      display: flex;
      justify-content: center;
      gap: 30px;
      flex-wrap: wrap;
      font-size: 0.9rem;
      color: #4a5568;
    }
    .footer-links a { color: #2b6cb0; text-decoration: none; font-weight: 500; }
    .footer-links a:hover { text-decoration: underline; }

    /* --- MODALES (inchangées) --- */
    .modal {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0,0,0,0.5);
      align-items: center;
      justify-content: center;
      z-index: 2000;
    }
    .modal-content {
      background: white;
      border-radius: 30px;
      padding: 35px 30px;
      max-width: 550px;
      width: 95%;
      max-height: 90vh;
      overflow-y: auto;
      box-shadow: 0 25px 60px rgba(0,0,0,0.3);
      text-align: left;
      position: relative;
    }
    .modal-content h2 { text-align: center; color: #1a365d; margin-bottom: 20px; }
    .modal-content label { font-weight: 600; display: block; margin: 10px 0 4px; }
    .modal-content input, .modal-content select {
      width: 100%;
      padding: 12px 16px;
      margin-bottom: 12px;
      border: 1px solid #cbd5e0;
      border-radius: 12px;
      font-size: 1rem;
      transition: border 0.2s;
    }
    .modal-content input:focus, .modal-content select:focus {
      border-color: #2b6cb0;
      outline: none;
      box-shadow: 0 0 0 3px rgba(43,108,176,0.2);
    }
    .modal-content input[type="file"] { padding: 8px; border: none; }
    .modal-content button {
      width: 100%;
      padding: 14px;
      border: none;
      border-radius: 12px;
      font-weight: 700;
      font-size: 1.1rem;
      cursor: pointer;
      transition: background 0.2s;
    }
    .btn-login { background: #2b6cb0; color: white; }
    .btn-login:hover { background: #1a4f8b; }
    .btn-register { background: #ed8936; color: white; margin-top: 8px; }
    .btn-register:hover { background: #dd6b20; }
    .btn-close { background: #e2e8f0; color: #2d3748; margin-top: 10px; }
    .btn-close:hover { background: #cbd5e0; }
    .btn-submit { background: #38a169; color: white; }
    .btn-submit:hover { background: #2f855a; }
    .btn-validate { background: #805ad5; color: white; }
    .btn-validate:hover { background: #6b46c1; }
    .modal-message {
      text-align: center;
      margin-top: 12px;
      font-weight: 500;
      font-size: 0.95rem;
    }
    .modal-message.error { color: #e53e3e; }
    .modal-message.success { color: #38a169; }
    .modal-extra {
      text-align: center;
      margin-top: 15px;
      font-size: 0.95rem;
    }
    .modal-extra a { color: #2b6cb0; cursor: pointer; font-weight: 600; }
    .modal-extra a:hover { text-decoration: underline; }
    .file-info { font-size: 0.9rem; color: #4a5568; margin-top: -8px; margin-bottom: 8px; }
    .step-indicator { display: flex; justify-content: center; gap: 20px; margin-bottom: 20px; }
    .step-indicator .step { padding: 8px 20px; border-radius: 30px; background: #e2e8f0; color: #4a5568; font-weight: 600; }
    .step-indicator .step.active { background: #2b6cb0; color: white; }
    .step-indicator .step.done { background: #38a169; color: white; }
  </style>
</head>
<body>

  <!-- Blobs décoratifs -->
  <div class="blob blob1"></div>
  <div class="blob blob2"></div>
  <div class="blob blob3"></div>

<div class="container">

  <!-- LOGO -->
  <div class="logo-area">
    <div class="logo-main">
      TRAFIC<span class="arrow">↗️</span> <span class="highlight">CLIC</span><span class="cursor">➤</span>
    </div>
    <div class="logo-sub">🚗 Covoiturage simple, rapide et sécurisé</div>
  </div>

  <!-- BANNIÈRE PUB -->
  <div class="pub-banner">
    📢 Offre spéciale : -20% sur vos 3 premiers trajets avec le code <strong>BIENVENUE20</strong> !
  </div>

  <!-- CHOIX -->
  <div class="choice-grid">
    <a href="#" class="choice-card chauffeur" id="btnChauffeur">
      <div class="icon">🚐</div>
      <h2>Espace Chauffeur</h2>
      <p>Publiez vos trajets, gérez vos réservations, suivez vos gains.</p>
    </a>
    <a href="/client.html" class="choice-card client">
      <div class="icon">👤</div>
      <h2>Espace Client</h2>
      <p>Recherchez un trajet, réservez en quelques clics, suivez vos réservations.</p>
    </a>
  </div>

  <div class="footer-links">
    <span>📞 +221 77 123 45 67</span>
    <span>📍 Dakar, Sénégal</span>
    <a href="#">À propos</a>
    <a href="#">Contact</a>
  </div>
</div>

<!-- ===== MODALES ===== -->
<!-- Modale Connexion -->
<div id="modalChauffeur" class="modal">
  <div class="modal-content">
    <h2>🔐 Espace Chauffeur</h2>
    <form id="loginForm">
      <input type="text" id="loginIdentifiant" placeholder="Identifiant" required>
      <input type="password" id="loginPassword" placeholder="Mot de passe" required>
      <button type="submit" class="btn-login">Se connecter</button>
    </form>
    <button id="btnInscription" class="btn-register">Créer un compte chauffeur</button>
    <button class="btn-close" onclick="fermerModal('modalChauffeur')">Fermer</button>
    <div id="loginMessage" class="modal-message"></div>
    <div class="modal-extra">
      <a onclick="ouvrirEtape1()">Pas encore inscrit ? Créez un compte</a>
    </div>
  </div>
</div>

<!-- Modale Étape 1 -->
<div id="modalEtape1" class="modal">
  <div class="modal-content">
    <div class="step-indicator">
      <span class="step active">📄 Étape 1/3</span>
      <span class="step">📸 Étape 2/3</span>
      <span class="step">🔐 Étape 3/3</span>
    </div>
    <h2>📄 Documents obligatoires</h2>
    <form id="formEtape1">
      <label>🪪 Permis de conduire – Recto</label>
      <input type="file" id="permis_recto" accept=".jpg,.jpeg,.png,.pdf" required>
      <div class="file-info" id="permis_recto-info">Aucun fichier</div>

      <label>🪪 Permis de conduire – Verso</label>
      <input type="file" id="permis_verso" accept=".jpg,.jpeg,.png,.pdf" required>
      <div class="file-info" id="permis_verso-info">Aucun fichier</div>

      <label>📄 Carte grise – Recto</label>
      <input type="file" id="carte_grise_recto" accept=".jpg,.jpeg,.png,.pdf" required>
      <div class="file-info" id="carte_grise_recto-info">Aucun fichier</div>

      <label>📄 Carte grise – Verso</label>
      <input type="file" id="carte_grise_verso" accept=".jpg,.jpeg,.png,.pdf" required>
      <div class="file-info" id="carte_grise_verso-info">Aucun fichier</div>

      <label>📄 Assurance (attestation)</label>
      <input type="file" id="assurance" accept=".jpg,.jpeg,.png,.pdf" required>
      <div class="file-info" id="assurance-info">Aucun fichier</div>

      <button type="button" class="btn-validate" onclick="validerEtape1()">✅ Valider les documents</button>
      <button class="btn-close" onclick="fermerModal('modalEtape1')">Annuler</button>
      <div id="messageEtape1" class="modal-message"></div>
    </form>
  </div>
</div>

<!-- Modale Étape 2 -->
<div id="modalEtape2" class="modal">
  <div class="modal-content">
    <div class="step-indicator">
      <span class="step done">📄 Étape 1/3</span>
      <span class="step active">📸 Étape 2/3</span>
      <span class="step">🔐 Étape 3/3</span>
    </div>
    <h2>📸 Photos du véhicule</h2>
    <form id="formEtape2">
      <label>📸 Photo de face</label>
      <input type="file" id="photo_face" accept=".jpg,.jpeg,.png" required>
      <div class="file-info" id="photo_face-info">Aucun fichier</div>

      <label>📸 Photo de profil</label>
      <input type="file" id="photo_profil" accept=".jpg,.jpeg,.png" required>
      <div class="file-info" id="photo_profil-info">Aucun fichier</div>

      <label>📸 Photo arrière</label>
      <input type="file" id="photo_arriere" accept=".jpg,.jpeg,.png" required>
      <div class="file-info" id="photo_arriere-info">Aucun fichier</div>

      <label>🔢 Numéro de plaque (sur la carte grise)</label>
      <input type="text" id="plaque" placeholder="Ex: AB-123-CD" required>

      <button type="button" class="btn-validate" onclick="validerEtape2()">✅ Valider les photos</button>
      <button class="btn-close" onclick="fermerModal('modalEtape2')">Annuler</button>
      <div id="messageEtape2" class="modal-message"></div>
    </form>
  </div>
</div>

<!-- Modale Étape 3 -->
<div id="modalEtape3" class="modal">
  <div class="modal-content">
    <div class="step-indicator">
      <span class="step done">📄 Étape 1/3</span>
      <span class="step done">📸 Étape 2/3</span>
      <span class="step active">🔐 Étape 3/3</span>
    </div>
    <h2>🔐 Créer votre compte chauffeur</h2>
    <form id="formEtape3">
      <input type="text" id="regIdentifiant" placeholder="Identifiant" required>
      <input type="password" id="regMotDePasse" placeholder="Mot de passe" required>
      <input type="password" id="regMotDePasseConfirm" placeholder="Confirmer le mot de passe" required>
      <input type="tel" id="regTelephone" placeholder="Téléphone" required>
      <input type="text" id="regCarteGrise" placeholder="Numéro carte grise (optionnel)">
      <input type="text" id="regAssurance" placeholder="Assurance (optionnel)">
      <button type="submit" class="btn-submit">S'inscrire</button>
    </form>
    <button class="btn-close" onclick="fermerModal('modalEtape3')">Fermer</button>
    <div id="messageEtape3" class="modal-message"></div>
    <div class="modal-extra">
      <a onclick="ouvrirConnexion()">Déjà un compte ? Se connecter</a>
    </div>
  </div>
</div>

<script>
  // Fonctions globales
  function fermerModal(id) {
    document.getElementById(id).style.display = 'none';
    document.querySelectorAll('.modal-message').forEach(el => el.textContent = '');
  }

  function ouvrirEtape1() {
    fermerModal('modalChauffeur');
    document.getElementById('modalEtape1').style.display = 'flex';
  }

  function ouvrirConnexion() {
    fermerModal('modalEtape3');
    document.getElementById('modalChauffeur').style.display = 'flex';
  }

  // Gestion des fichiers (affichage des noms)
  document.querySelectorAll('#formEtape1 input[type="file"], #formEtape2 input[type="file"]').forEach(input => {
    input.addEventListener('change', function() {
      const info = document.getElementById(this.id + '-info');
      if (this.files.length === 0) { info.textContent = 'Aucun fichier'; return; }
      info.textContent = Array.from(this.files).map(f => f.name).join(', ');
    });
  });

  // Lire un fichier en base64
  function lireFichier(file) {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => resolve(reader.result);
      reader.onerror = reject;
      reader.readAsDataURL(file);
    });
  }

  // --- Étape 1 : Valider les documents ---
  async function validerEtape1() {
    const msg = document.getElementById('messageEtape1');
    msg.textContent = '';
    msg.className = 'modal-message';

    const fields = ['permis_recto', 'permis_verso', 'carte_grise_recto', 'carte_grise_verso', 'assurance'];
    const files = {};
    let allOk = true;

    for (const field of fields) {
      const input = document.getElementById(field);
      if (input.files.length === 0) {
        msg.textContent = `Veuillez sélectionner le fichier pour "${field}".`;
        msg.className = 'modal-message error';
        allOk = false;
        break;
      }
      files[field] = input.files[0];
    }
    if (!allOk) return;

    try {
      msg.textContent = '⏳ Lecture des fichiers...';
      msg.className = 'modal-message';

      const base64Data = {};
      for (const [key, file] of Object.entries(files)) {
        base64Data[key] = await lireFichier(file);
      }

      msg.textContent = '⏳ Validation en cours...';
      const res = await fetch('/api/auth/validate-documents', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(base64Data)
      });
      const data = await res.json();
      if (res.ok) {
        msg.textContent = '✅ ' + data.message;
        msg.className = 'modal-message success';
        window.documentsValides = base64Data;
        setTimeout(() => {
          fermerModal('modalEtape1');
          document.getElementById('modalEtape2').style.display = 'flex';
        }, 1200);
      } else {
        msg.textContent = '❌ ' + (data.error || 'Erreur de validation.');
        msg.className = 'modal-message error';
      }
    } catch (err) {
      msg.textContent = '❌ Erreur réseau : ' + err.message;
      msg.className = 'modal-message error';
    }
  }

  // --- Étape 2 : Valider les photos ---
  async function validerEtape2() {
    const msg = document.getElementById('messageEtape2');
    msg.textContent = '';
    msg.className = 'modal-message';

    const fields = ['photo_face', 'photo_profil', 'photo_arriere'];
    const files = {};
    let allOk = true;

    for (const field of fields) {
      const input = document.getElementById(field);
      if (input.files.length === 0) {
        msg.textContent = `Veuillez sélectionner la photo "${field}".`;
        msg.className = 'modal-message error';
        allOk = false;
        break;
      }
      files[field] = input.files[0];
    }

    const plaque = document.getElementById('plaque').value.trim().toUpperCase();
    if (!plaque) {
      msg.textContent = 'Veuillez saisir le numéro de plaque.';
      msg.className = 'modal-message error';
      return;
    }
    if (!allOk) return;

    try {
      msg.textContent = '⏳ Lecture des photos...';
      msg.className = 'modal-message';

      const base64Data = {};
      for (const [key, file] of Object.entries(files)) {
        base64Data[key] = await lireFichier(file);
      }

      msg.textContent = '⏳ Vérification de la plaque...';
      const res = await fetch('/api/auth/validate-vehicle-photos', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ...base64Data, plaque_attendue: plaque })
      });
      const data = await res.json();
      if (res.ok) {
        msg.textContent = '✅ ' + data.message;
        msg.className = 'modal-message success';
        window.photosValides = base64Data;
        setTimeout(() => {
          fermerModal('modalEtape2');
          document.getElementById('modalEtape3').style.display = 'flex';
        }, 1200);
      } else {
        msg.textContent = '❌ ' + (data.error || 'Erreur de validation.');
        msg.className = 'modal-message error';
      }
    } catch (err) {
      msg.textContent = '❌ Erreur réseau : ' + err.message;
      msg.className = 'modal-message error';
    }
  }

  // --- Connexion ---
  document.getElementById('loginForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const identifiant = document.getElementById('loginIdentifiant').value.trim();
    const mot_de_passe = document.getElementById('loginPassword').value.trim();
    const msg = document.getElementById('loginMessage');

    if (!identifiant || !mot_de_passe) {
      msg.textContent = 'Veuillez remplir tous les champs.';
      msg.className = 'modal-message error';
      return;
    }
    try {
      const res = await fetch('/api/auth/chauffeur', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ identifiant, mot_de_passe })
      });
      const data = await res.json();
      if (res.ok) {
        msg.textContent = '✅ Connexion réussie ! Redirection...';
        msg.className = 'modal-message success';
        setTimeout(() => { window.location.href = '/chauffeur.html'; }, 1000);
      } else {
        msg.textContent = '❌ ' + (data.error || 'Identifiant ou mot de passe incorrect.');
        msg.className = 'modal-message error';
      }
    } catch (err) {
      msg.textContent = '❌ Erreur réseau : ' + err.message;
      msg.className = 'modal-message error';
    }
  });

  // --- Étape 3 : Inscription finale ---
  document.getElementById('formEtape3').addEventListener('submit', async function(e) {
    e.preventDefault();
    const identifiant = document.getElementById('regIdentifiant').value.trim();
    const mot_de_passe = document.getElementById('regMotDePasse').value.trim();
    const confirm = document.getElementById('regMotDePasseConfirm').value.trim();
    const telephone = document.getElementById('regTelephone').value.trim();
    const carte_grise = document.getElementById('regCarteGrise').value.trim();
    const assurance = document.getElementById('regAssurance').value.trim();
    const msg = document.getElementById('messageEtape3');

    if (!identifiant || !mot_de_passe || !confirm || !telephone) {
      msg.textContent = 'Identifiant, mot de passe, confirmation et téléphone sont obligatoires.';
      msg.className = 'modal-message error';
      return;
    }
    if (mot_de_passe !== confirm) {
      msg.textContent = 'Les mots de passe ne correspondent pas.';
      msg.className = 'modal-message error';
      return;
    }

    try {
      const res = await fetch('/api/auth/register/chauffeur', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          identifiant,
          mot_de_passe,
          telephone,
          carte_grise: carte_grise || null,
          assurance: assurance || null,
          documents: window.documentsValides || {},
          photos: window.photosValides || {}
        })
      });
      const data = await res.json();
      if (res.ok) {
        msg.textContent = '✅ ' + data.message;
        msg.className = 'modal-message success';
        setTimeout(() => {
          fermerModal('modalEtape3');
          document.getElementById('modalChauffeur').style.display = 'flex';
          document.getElementById('loginMessage').textContent = 'Compte créé ! Veuillez vous connecter.';
          document.getElementById('loginMessage').className = 'modal-message success';
        }, 1200);
      } else {
        msg.textContent = '❌ ' + (data.error || 'Erreur lors de l\'inscription.');
        msg.className = 'modal-message error';
      }
    } catch (err) {
      msg.textContent = '❌ Erreur réseau : ' + err.message;
      msg.className = 'modal-message error';
    }
  });

  // --- Ouverture de la connexion ---
  document.getElementById('btnChauffeur').addEventListener('click', function(e) {
    e.preventDefault();
    document.getElementById('modalChauffeur').style.display = 'flex';
  });

  document.getElementById('btnInscription').addEventListener('click', function() {
    ouvrirEtape1();
  });

  // --- Fermeture en cliquant à l'extérieur ---
  document.querySelectorAll('.modal').forEach(modal => {
    modal.addEventListener('click', function(e) {
      if (e.target === this) {
        this.style.display = 'none';
        document.querySelectorAll('.modal-message').forEach(el => el.textContent = '');
      }
    });
  });
</script>

</body>
</html>
