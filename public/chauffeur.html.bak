// ====== NETTOYAGE AUTOMATIQUE toutes les 10 min ======
setInterval(() => {
  nettoyerTrajets();
}, 10 * 60 * 1000);

// ====== INIT ======
loadStatut();
loadMesTrajets();
loadTrajets();

// Rafraîchissement toutes les 30s
setInterval(() => {
  const actif = document.querySelector('.nav-btn.active');
  if (actif && actif.dataset.onglet === 'enregistrement') loadMesTrajets();
  if (actif && actif.dataset.onglet === 'trajets') loadTrajets();
}, 30000);
</script>
